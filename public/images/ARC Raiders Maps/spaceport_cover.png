        <script>
            window.debugShowPreferencesMultipartPopup = function(options = {}) {
                const scriptLocation = window.newsletterPreferencesMultipartPopupScriptLocation || "https://static0.polygonimages.com/assets/newsletter-preferences-multipart-popup.03a177d3.js";
                const hidePreferences = !!options.hidePreferences;
                const place = options.place || null;
                const showVerifyMessage = options.showVerifyMessage !== false;
                const forceReload = !!options.forceReload;

                const openPopup = function() {
                    if (typeof window.showPreferencesMultipartPopup !== 'function') {
                        console.error('showPreferencesMultipartPopup is not available.');
                        return;
                    }

                    window.showPreferencesMultipartPopup(null, hidePreferences, place, showVerifyMessage);
                };

                if (!forceReload && typeof window.showPreferencesMultipartPopup === 'function') {
                    openPopup();
                    return Promise.resolve();
                }

                if (forceReload) {
                    window.showPreferencesMultipartPopup = null;
                }

                return new Promise(function(resolve, reject) {
                    const script = document.createElement('script');
                    script.src = forceReload
                        ? scriptLocation + (scriptLocation.includes('?') ? '&' : '?') + 'debug_ts=' + Date.now()
                        : scriptLocation;
                    script.onload = function() {
                        openPopup();
                        resolve();
                    };
                    script.onerror = function() {
                        reject(new Error('Failed to load preferences multipart popup script.'));
                    };
                    document.head.appendChild(script);
                });
            };
        </script>

