# -----------------------------------------------------------------------------
# Copy to `.env.local` for local development (never commit real secrets).
# On Vercel: Project → Settings → Environment Variables (Production + Preview).
# -----------------------------------------------------------------------------

# --- Optional: sticky dev banner (see src/components/DevBanner.tsx) ----------
# 0 or false = never show. 1 or true = always show. Unset = show only in development.
# NEXT_PUBLIC_SHOW_DEV_BANNER=0

# --- Maps: TroubleChute iframe (see src/lib/maps/tcno-embed.ts) ---------------
# Production on raiderforge.org uses linked preview (TCNO CSP). To force an iframe
# attempt locally (often blank unless your origin is allowlisted), set:
# NEXT_PUBLIC_TCNO_IFRAME_FORCE=1
# To disable iframe even on allowlisted hosts:
# NEXT_PUBLIC_TCNO_IFRAME=0

# --- Database (required for email magic link + DB-backed sessions) -----------
# SQLite (local):  file:dev.db  (resolved next to prisma/schema.prisma → prisma/dev.db). Run: npx prisma migrate dev
# Production:      PostgreSQL URL from your host
DATABASE_URL=

# --- NextAuth (required for OAuth) -------------------------------------------
# Public site URL — must match the browser origin (no trailing slash).
# Local:        http://localhost:3000
# Production:   https://raiderforge.org
NEXTAUTH_URL=http://localhost:3000

# Generate once:  openssl rand -base64 32
NEXTAUTH_SECRET=

# --- Google OAuth (Google Cloud Console → APIs & Services → Credentials) -----
# Authorized redirect URI (exact):
#   http://localhost:3000/api/auth/callback/google
#   https://raiderforge.org/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Discord OAuth (Discord Developer Portal → OAuth2) -----------------------
# Redirects (exact):
#   http://localhost:3000/api/auth/callback/discord
#   https://raiderforge.org/api/auth/callback/discord
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# --- Optional: NextAuth Email (magic link) ------------------------------------
# Requires DATABASE_URL and a migrated Prisma schema (see prisma/).
# Either set EMAIL_SERVER (connection string, e.g. smtp://user:pass@smtp:587)
# or use host/port/user/password below.
EMAIL_SERVER=
EMAIL_SERVER_HOST=
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=
EMAIL_SERVER_PASSWORD=
EMAIL_FROM=

# --- MetaForge / ARDB / G2G (existing app config) -----------------------------
METAFORGE_API_BASE=
METAFORGE_API_KEY=

ARDB_API_BASE=
ARDB_API_KEY=

# ── G2G OpenAPI Integration (server-only — NEVER expose these on the client) ──
# Docs: https://docs.g2g.com/
# Setup: Add these to Vercel → Project → Settings → Environment Variables (Production).
# On the client only NEXT_PUBLIC_G2G_INTEGRATION_ENABLED is available (true/false flag).
#
# All signed G2G HTTP requests go through server-side API routes (/api/marketplace/*).
# The keys below are loaded via src/config/env.ts — see g2gEnv.
#
# Primary keys (used by src/config/env.ts):
G2G_API_KEY=
# Alias: G2G_ACCESS_KEY_ID=   (legacy name, same value)

G2G_SECRET_KEY=
# Alias: G2G_SECRET_ACCESS_KEY=  (legacy name, same value)

G2G_USERNAME=
# Alias: G2G_USER_ID=            (legacy name, same value)

# G2G API base URL (default: https://sls.g2g.com)
G2G_API_BASE=https://sls.g2g.com

# Webhook HMAC secret from G2G dashboard — server-only, validates incoming webhooks
G2G_WEBHOOK_SECRET=

# Full URL of this site's G2G webhook endpoint (registered in G2G dashboard)
G2G_WEBHOOK_URL=https://raiderforge.org/api/webhooks/g2g

# Optional: minimum ms between outbound G2G requests (default 250, prevents rate-limiting)
# G2G_MIN_REQUEST_INTERVAL_MS=250

# Public flag — safe to expose, just signals integration is configured (no keys)
# NEXT_PUBLIC_G2G_INTEGRATION_ENABLED=false

# --- Public site URL (Open Graph, Twitter/X cards, skill-trees metadataBase, share links) ---
# Must match the browser origin in production (no trailing slash). Used by getSiteOrigin() and
# buildSkillTreeShareUrl() so “Copy share link” and social crawlers use the same absolute URL.
# Local dev can omit or set to http://localhost:3000 for accurate OG during testing.
# NEXT_PUBLIC_SITE_URL=https://raiderforge.org
