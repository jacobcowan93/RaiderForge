# -----------------------------------------------------------------------------
# Local development template — copy to `.env.local` and fill in values.
# Next.js loads `.env.local` automatically (gitignored).
# -----------------------------------------------------------------------------

NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=YOUR_NEXTAUTH_SECRET_HERE

GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET_HERE

DISCORD_CLIENT_ID=YOUR_DISCORD_APPLICATION_ID
DISCORD_CLIENT_SECRET=YOUR_DISCORD_CLIENT_SECRET_HERE

# Required for email magic link (same DB stores OAuth users/sessions when set)
DATABASE_URL=file:dev.db

# Optional SMTP — omit to disable Email sign-in (Google + Discord still work)
# EMAIL_SERVER=smtp://user:pass@smtp.example.com:587
# EMAIL_SERVER_HOST=smtp.example.com
# EMAIL_SERVER_PORT=587
# EMAIL_SERVER_USER=
# EMAIL_SERVER_PASSWORD=
# EMAIL_FROM=noreply@yourdomain.com

METAFORGE_API_BASE=
METAFORGE_API_KEY=

ARDB_API_BASE=
ARDB_API_KEY=

G2G_API_BASE=
G2G_API_KEY=
G2G_SECRET=
G2G_USERNAME=
G2G_WEBHOOK_URL=
G2G_USER_ID=
