# -----------------------------------------------------------------------------
# Copy to `.env.local` for local development (never commit real secrets).
# On Vercel: Project → Settings → Environment Variables (Production + Preview).
# -----------------------------------------------------------------------------

# --- Database (required for email magic link + DB-backed sessions) -----------
# SQLite (local):  file:dev.db  (resolved next to prisma/schema.prisma → prisma/dev.db). Run: npx prisma migrate dev
# Production:      PostgreSQL URL from your host
DATABASE_URL=

# --- NextAuth (required for OAuth) -------------------------------------------
# Public site URL — must match the browser origin (no trailing slash).
# Local:        http://localhost:3000
# Production:   https://raiderforge.org
NEXTAUTH_URL=http://localhost:3000

# Generate once:  openssl rand -base64 32
NEXTAUTH_SECRET=

# --- Google OAuth (Google Cloud Console → APIs & Services → Credentials) -----
# Authorized redirect URI (exact):
#   http://localhost:3000/api/auth/callback/google
#   https://raiderforge.org/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Discord OAuth (Discord Developer Portal → OAuth2) -----------------------
# Redirects (exact):
#   http://localhost:3000/api/auth/callback/discord
#   https://raiderforge.org/api/auth/callback/discord
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# --- Optional: NextAuth Email (magic link) ------------------------------------
# Requires DATABASE_URL and a migrated Prisma schema (see prisma/).
# Either set EMAIL_SERVER (connection string, e.g. smtp://user:pass@smtp:587)
# or use host/port/user/password below.
EMAIL_SERVER=
EMAIL_SERVER_HOST=
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=
EMAIL_SERVER_PASSWORD=
EMAIL_FROM=

# --- MetaForge / ARDB / G2G (existing app config) -----------------------------
METAFORGE_API_BASE=
METAFORGE_API_KEY=

ARDB_API_BASE=
ARDB_API_KEY=

# G2G OpenAPI (server-only). Legacy aliases in parentheses — see src/lib/marketplace/g2g/env.ts
G2G_API_BASE=
# Optional override for base URL env name:
# G2G_API_BASE_URL=

G2G_ACCESS_KEY_ID=
# (alias) G2G_API_KEY=

G2G_SECRET_ACCESS_KEY=
# (alias) G2G_SECRET=

G2G_USER_ID=
# (alias) G2G_USERNAME=

# Webhook HMAC secret from G2G dashboard (Phase 5); keep server-only
G2G_WEBHOOK_SECRET=

# Optional: minimum ms between outbound G2G requests (default 250)
# G2G_MIN_REQUEST_INTERVAL_MS=

G2G_WEBHOOK_URL=
